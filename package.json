{
  "name": "banter",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/shell",
    "packages/api"
  ],
  "scripts": {
    "dev": "npm run copy-games -w packages/shell && npm run dev -w packages/shell",
    "build": "npm run copy-games -w packages/shell && npm run build -w packages/shell",
    "start": "npm run start -w packages/shell",
    "test": "npm run test -w packages/shell",
    "copy-games": "npm run copy-games -w packages/shell",
    "seed-daily": "node scripts/seed-daily-games.mjs",
    "seed-packs": "node scripts/seed-packs.mjs",
    "dev:api": "npm run dev -w packages/api",
    "build:api": "npm run build -w packages/api",
    "start:api": "npm run start -w packages/api",
    "test:api": "npm run test -w packages/api"
  }
}
